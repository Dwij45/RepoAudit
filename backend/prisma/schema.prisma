generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url      = env("DATABASE_URL")
}

model User{
  id Int @id @default(autoincrement())
  name String
  email String @unique
  password String
  createdAt DateTime @default(now())
  scans     ScanResult[]
  ruleConfigs UserRuleConfig[]
}
model ScanResult {  
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  riskSeverity String // "LOW" | "MEDIUM" | "HIGH" 
  status      String   // "PASS" or "BLOCK"
  violations  Json     // stores the full violations array as JSON
  scannedAt   DateTime @default(now())
}
model UserRuleConfig {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  ruleId     String   // e.g., "SEC001", "GIT002"
  enabled    Boolean  @default(true)
  severity   String?  // Optional override: "HIGH", "MEDIUM", "LOW"

  @@unique([userId, ruleId])
}
